# ─── Supabase ───────────────────────────────────────────────
# From your project settings > API: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── x402 / Circle Gateway wallets (Arc Testnet) ────────────
# Run `npm run generate-wallets` to auto-generate both wallets.
# BUYER funds x402 payments AND signs on-chain provenance anchors (needs native gas).
# SELLER is the platform/settlement wallet.
SELLER_ADDRESS=0xYourSellerWalletAddress
SELLER_PRIVATE_KEY=0xYourSellerPrivateKey
BUYER_ADDRESS=0xYourBuyerWalletAddress
BUYER_PRIVATE_KEY=0xYourBuyerPrivateKey

# ─── Chat LLM (Groq — classification, judgment, synthesis) ──
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=your-groq-api-key
CHAT_MODEL=llama-3.3-70b-versatile

# ─── Embeddings (Google AI Studio — retrieval + cache) ──────
# Model: gemini-embedding-001 at 768 dimensions (matches the DB vector column)
GOOGLE_API_KEY=your-google-ai-studio-key

# ─── Transcription (Groq Whisper) ───────────────────────────
# Uses the same Groq key above (whisper-large-v3)

# ─── App ────────────────────────────────────────────────────
# Agents call the app's own API routes — must be the deployed URL in production
BASE_URL=http://localhost:3000
